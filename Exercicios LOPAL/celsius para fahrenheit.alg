algoritmo "celsius para fahrenheit"
// Disciplina:  LOPAL (Lógica de Programação)

// F9 (Executa meu código)

// Autor: Enzo Ferrari
// Data: 13/04/2026
var

 c, f: real

inicio
// entrada de dados

 escreva("Digite a temperatura em Celsius: ")
 leia(c)

 f <- ((9 * c) / 5) + 32

 limpatela

 escreval("Temperatura em Fahrenheit: ", f)

fimalgoritmo
